# ==============================================================================
# THE VAGABOND — ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================

# Application Environment (development / production)
APP_ENV=development

# Telegram Bot API Configuration
# Get your token from Telegram @BotFather
TELEGRAM_TOKEN=1234567890:YOUR_TELEGRAM_BOT_TOKEN

# Supabase PostgreSQL Database URL
# Format: postgres://postgres.[PROJECT_ID]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgres://user:password@host:port/dbname?sslmode=require

# Master Game Tick Rate (In seconds)
# Default is 60 seconds for live operations
GAME_TICK_SECONDS=60